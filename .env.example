# Copia in .env.local e compila con i tuoi valori
# .env.local NON va committato (già in .gitignore)

# ── Firebase (da Firebase Console → Impostazioni progetto → Le tue app → Web) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── GitHub (usato solo per sapere il repo dove stanno i capitoli .md) ──
VITE_GITHUB_REPO_OWNER=your_github_username
VITE_GITHUB_REPO_NAME=book-personal
