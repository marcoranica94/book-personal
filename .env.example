# Copia in .env.local e compila con i tuoi valori
# .env.local NON va committato (già in .gitignore)

# GitHub OAuth App Client ID (dalla pagina https://github.com/settings/developers)
VITE_GITHUB_CLIENT_ID=your_oauth_app_client_id

# Il tuo username GitHub
VITE_GITHUB_REPO_OWNER=your_github_username

# Nome del repository (default: book-personal)
VITE_GITHUB_REPO_NAME=book-personal
