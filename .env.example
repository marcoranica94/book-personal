# Copia in .env.local e compila con i tuoi valori
# .env.local NON va committato (già in .gitignore)

# ── Firebase (da Firebase Console → Impostazioni progetto → Le tue app → Web) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── GitHub (usato solo per sapere il repo dove stanno i capitoli .md) ──
VITE_GITHUB_REPO_OWNER=your_github_username
VITE_GITHUB_REPO_NAME=book-personal

# ── Accesso — solo questo UID Firebase può loggarsi (Firebase Console → Auth → Users) ──
VITE_ALLOWED_UID=your_firebase_uid

# ── Google Drive OAuth (da Google Cloud Console → OAuth 2.0 Client ID) ──
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Client Secret — necessario per token exchange con client type "Web application"
VITE_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Chiave AES-256 in base64 per cifrare il refresh token in Firestore.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VITE_DRIVE_ENCRYPTION_KEY=your_32byte_base64_key
